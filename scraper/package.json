{
  "name": "hirin-scraper",
  "version": "0.1.0",
  "private": true,
  "description": "Hirin scraper microservice — runs Playwright on Railway, decoupled from Vercel.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "postinstall": "playwright install chromium --with-deps"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "express": "^4.21.0",
    "playwright": "^1.58.1",
    "zod": "^3.23.8",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
