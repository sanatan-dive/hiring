{
  "manifest_version": 3,
  "name": "Hirin' — Job Application Autofill",
  "short_name": "Hirin",
  "description": "Autofill application forms from your Hirin profile. Save jobs while you browse.",
  "version": "0.1.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Hirin",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.linkedin.com/jobs/*",
        "*://*.linkedin.com/jobs/view/*",
        "*://boards.greenhouse.io/*",
        "*://jobs.lever.co/*",
        "*://jobs.ashbyhq.com/*",
        "*://*.workday.com/*",
        "*://wellfound.com/jobs/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["https://hirin.app/*", "http://localhost:3000/*"],
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
